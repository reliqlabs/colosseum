# Colosseum environment configuration — example file.
#
# Copy this to `.env` in this repo root (or to `~/.colosseum.env` for a
# user-global config) and fill in the values you need. The real .env is
# gitignored; only this .example file is tracked.
#
# Load order used by external-model-mcp (and any other MCP that links
# python-dotenv against the same names):
#
#   1. $COLOSSEUM_DOTENV (explicit override path)
#   2. ./.env (CWD-local; useful for per-project overrides)
#   3. <colosseum repo root>/.env (this file's sibling)
#   4. ~/.colosseum.env (user-global)
#
# Existing OS environment variables take precedence; nothing here overrides
# what you've already exported in your shell.

# ─────────────────────────────────────────────────────────────────────────
# Multi-model gateway (OpenAI-compatible, routes to multiple upstreams)
# ─────────────────────────────────────────────────────────────────────────
# URL and key together: both required, both kept out of the codebase.
# If you only have one set, the gateway is reported as not configured and
# all gateway tools return a clear error.
COLOSSEUM_GATEWAY_API_KEY=
COLOSSEUM_GATEWAY_BASE_URL=
# Optional. If unset, callers must supply a model name explicitly per request.
COLOSSEUM_GATEWAY_DEFAULT_MODEL=

# ─────────────────────────────────────────────────────────────────────────
# Direct OpenAI API
# ─────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Optional overrides
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_DEFAULT_MODEL=gpt-4o

# ─────────────────────────────────────────────────────────────────────────
# Direct Google Gemini API
# ─────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
# GOOGLE_API_KEY= (legacy alias also accepted)
# Optional overrides
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GOOGLE_DEFAULT_MODEL=gemini-2.0-flash-exp

# ─────────────────────────────────────────────────────────────────────────
# Cross-provider timeout (seconds, single-shot completions)
# ─────────────────────────────────────────────────────────────────────────
# EXTERNAL_MODEL_TIMEOUT_S=300
